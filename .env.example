# Copy to .env and fill in your target account/region.
# The scripts and CDK read these; nothing else is hardcoded.

# The account and region where all four stacks deploy (single-account POC).
CDK_PROCESSING_ACCOUNT=123456789012
CDK_PROCESSING_REGION=us-east-1

# SSM Parameter Store prefix for demo state.
SSM_PREFIX=/devops-agent-networking
